{
    "multipart": [
        { "when": { "up": "true" }, "apply": { "model": "more_copycats:block/wall/root" } },

        { "when": { "north": "low"  }, "apply": { "model": "more_copycats:block/wall/side",      "uvlock": true } },
        { "when": { "north": "tall" }, "apply": { "model": "more_copycats:block/wall/side_full", "uvlock": true } },

        { "when": { "east": "low"   }, "apply": { "model": "more_copycats:block/wall/side",      "y": 90,  "uvlock": true } },
        { "when": { "east": "tall"  }, "apply": { "model": "more_copycats:block/wall/side_full", "y": 90,  "uvlock": true } },

        { "when": { "south": "low"  }, "apply": { "model": "more_copycats:block/wall/side",      "y": 180, "uvlock": true } },
        { "when": { "south": "tall" }, "apply": { "model": "more_copycats:block/wall/side_full", "y": 180, "uvlock": true } },

        { "when": { "west": "low"   }, "apply": { "model": "more_copycats:block/wall/side",      "y": 270, "uvlock": true } },
        { "when": { "west": "tall"  }, "apply": { "model": "more_copycats:block/wall/side_full", "y": 270, "uvlock": true } }
    ]
}
