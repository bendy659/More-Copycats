{
    "multipart": [
        { "apply": { "model": "more_copycats:block/fence/root" } },

        { "when": { "north": "true" }, "apply": { "model": "more_copycats:block/fence/side", "y": 0   } },
        { "when": { "east" : "true" }, "apply": { "model": "more_copycats:block/fence/side", "y": 90  } },
        { "when": { "south": "true" }, "apply": { "model": "more_copycats:block/fence/side", "y": 180 } },
        { "when": { "west" : "true" }, "apply": { "model": "more_copycats:block/fence/side", "y": 270 } }
    ]
}