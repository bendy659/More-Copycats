{
    "multipart": [
        {
            "when": { "axis": "x", "type": "bottom" },
            "apply": { "model": "more_copycats:block/slab_part", "x": 90, "y": 90 }
        },
        {
            "when": { "axis": "x", "type": "top" },
            "apply": { "model": "more_copycats:block/slab_part", "x": 90, "y": -90 }
        },
        {
            "when": { "axis": "x", "type": "double" },
            "apply": { "model": "more_copycats:block/slab_part", "x": 90, "y": 90 }
        },
        {
            "when": { "axis": "x", "type": "double" },
            "apply": { "model": "more_copycats:block/slab_part", "x": 90, "y": -90 }
        },

        {
            "when": { "axis": "y", "type": "bottom" },
            "apply": { "model": "more_copycats:block/slab_part" }
        },
        {
            "when": { "axis": "y", "type": "top" },
            "apply": { "model": "more_copycats:block/slab_part", "x": 180 }
        },
        {
            "when": { "axis": "y", "type": "double" },
            "apply": { "model": "more_copycats:block/slab_part" }
        },
        {
            "when": { "axis": "y", "type": "double" },
            "apply": { "model": "more_copycats:block/slab_part", "x": 180 }
        },

        {
            "when": { "axis": "z", "type": "bottom" },
            "apply": { "model": "more_copycats:block/slab_part", "x": 90, "y": 180 }
        },
        {
            "when": { "axis": "z", "type": "top" },
            "apply": { "model": "more_copycats:block/slab_part", "x": -90, "y": -180 }
        },
        {
            "when": { "axis": "z", "type": "double" },
            "apply": { "model": "more_copycats:block/slab_part", "x": 90, "y": 180 }
        },
        {
            "when": { "axis": "z", "type": "double" },
            "apply": { "model": "more_copycats:block/slab_part", "x": -90, "y": -180 }
        }
    ]
}